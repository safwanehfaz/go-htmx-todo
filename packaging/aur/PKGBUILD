pkgname=togx
pkgver=0.1.2
pkgrel=1
pkgdesc="Minimal todo app with pure Go and HTMX"
_repo_owner="safwanehfaz"
_repo_name="go-htmx-todo"
arch=('x86_64' 'aarch64')
url="https://github.com/${_repo_owner}/${_repo_name}"
license=('MIT')
depends=('glibc')
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::https://github.com/${_repo_owner}/${_repo_name}/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$srcdir/${_repo_name}-${pkgver}"
  export CGO_ENABLED=0
  export GOFLAGS="-trimpath"
  go build -ldflags='-s -w' -o "$pkgname" .
}

package() {
  cd "$srcdir/${_repo_name}-${pkgver}"
  install -Dm755 "$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
